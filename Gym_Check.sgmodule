#!name=Gym Check
#!desc=自动抓取健身房查询 Cookie 并定时检查状态。
#!system=mac
#!category=Local

[Script]
# 获取 Cookie 的脚本
Gym_Cookie = type=http-request, pattern=^https://byty.bupt.edu.cn/bdlp_h5_fitness_test/public/index.php/index/Stadium/getInterval, script-path=https://strike20023.github.io/get_gym_cookie.js, requires-body=true

# 定时检查脚本 (每10分钟)
Gym_Check = type=cron, cronexp="*/10 * * * *", script-path=https://strike20023.github.io/check_gym.js

[MITM]
hostname = %APPEND% byty.bupt.edu.cn
